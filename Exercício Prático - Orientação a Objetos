from abc import ABC, abstractmethod
from datetime import datetime, timedelta


# ==========================
# Q1 - Classe abstrata EventoABC
# ==========================
class EventoABC(ABC):

    def __init__(self, titulo, descricao):
        self._titulo = titulo
        self._descricao = descricao

    @abstractmethod
    def __str__(self):
        pass

    @abstractmethod
    def isConcluido(self):
        pass


# ==========================
# Q2 - Classe DataHora
# ==========================
class DataHora:

    FORMAT = '%d/%m/%Y, %H:%M'

    @property
    def data_hora(self):
        return self._data_hora.strftime(self.FORMAT)

    @data_hora.setter
    def data_hora(self, valor):
        try:
            self._data_hora = datetime.strptime(valor, self.FORMAT)
        except:
            raise ValueError(
                "Data inválida. Use %d/%m/%Y, %H:%M"
            )

    def isPassado(self):
        return self._data_hora < datetime.now()

    def somaDias(self, num_dias):
        nova = self._data_hora + timedelta(days=num_dias)
        return nova.strftime(self.FORMAT)


# ==========================
# TESTE Q2
# ==========================
dh = DataHora()

dh.data_hora = '05/02/2024, 12:30'

dh.data_hora = dh.somaDias(30)

print(dh.data_hora, dh.isPassado())


# ==========================
# Q3 - EventoUnico
# ==========================
class EventoUnico(EventoABC):

    def __init__(self, titulo, descricao, data_hora):

        super().__init__(titulo, descricao)

        self._data_hora = DataHora()
        self._data_hora.data_hora = data_hora

    def isConcluido(self):
        return self._data_hora.isPassado()

    def editar_data_hora(self, nova_data):
        self._data_hora.data_hora = nova_data

    def __str__(self):

        return (
            f'Evento: {self._titulo}, '
            f'Data: {self._data_hora.data_hora}, '
            f'Descrição: {self._descricao}, '
            f'Concluído: {self.isConcluido()}'
        )


# TESTE
evento = EventoUnico(
    'Reunião',
    'Sala 302, prédio da esquina',
    '05/10/2023, 16:30'
)

print(evento)

evento.editar_data_hora(
