print(evento)


# ==========================
# Q3 - EventoRecorrente
# ==========================
class EventoRecorrente(EventoABC):

    def __init__(
            self,
            titulo,
            descricao,
            data_inicial,
            data_final,
            intervalo):

        super().__init__(titulo, descricao)

        self._datas_hora = []

        atual = DataHora()
        atual.data_hora = data_inicial

        limite = datetime.strptime(
            data_final,
            DataHora.FORMAT
        )

        while atual._data_hora <= limite:

            novo = DataHora()
            novo.data_hora = atual.data_hora

            self._datas_hora.append(novo)

            atual.data_hora = atual.somaDias(
                intervalo
            )

    def isConcluido(self, indice=0):

        return (
            self._datas_hora[indice]
            .isPassado()
        )

    def editar_data_hora(
            self,
            antiga,
            nova):

        for item in self._datas_hora:

            if item.data_hora == antiga:
                item.data_hora = nova
                break

    def __str__(self):

        texto = ''

        for i, item in enumerate(
                self._datas_hora):

            texto += (
                f'Evento: {self._titulo}, '
                f'Data: {item.data_hora}, '
                f'Descrição: {self._descricao}, '
                f'Concluído: {self.isConcluido(i)}\n'
            )

        return texto


# TESTE
