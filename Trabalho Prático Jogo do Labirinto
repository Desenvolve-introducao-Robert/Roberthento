"""
Arquivo principal do jogo.
"""

import argparse
import time

from aventura_pkg.labirinto import (
    criar_labirinto,
    imprimir_labirinto
)

from aventura_pkg.jogador import (
    iniciar_jogador,
    mover,
    resolver_labirinto
)

from aventura_pkg.utils import (
    imprimir_menu,
    imprimir_instrucoes,
    animacao_vitoria
)


def main():

    parser = argparse.ArgumentParser(
        description="Jogo Aventura no Labirinto"
    )

    parser.add_argument(
        "--name",
        required=True,
        help="Nome do jogador"
    )

    parser.add_argument(
        "--color",
        default="green",
        help="Cor principal"
    )

    parser.add_argument(
        "--dificuldade",
        type=int,
        default=1,
        help="Dificuldade do jogo"
    )

    parser.add_argument(
        "--disable-sound",
        action="store_true",
        help="Desliga sons"
    )

    parser.add_argument(
        "--max-moves",
        type=int,
        default=100,
        help="Máximo de movimentos"
    )

    args = parser.parse_args()

    while True:

        imprimir_menu()

        opcao = input("Escolha: ")

        match opcao:

            case "1":

                tamanho = 10 + args.dificuldade * 2

                lab = criar_labirinto(
                    tamanho,
                    tamanho
                )

                jogador = iniciar_jogador()

                venceu = False

                movimentos = 0

                while not venceu and movimentos < args.max_moves:

                    imprimir_labirinto(lab)

                    print(
                        f"Jogador: {args.name}"
                    )

                    print(
                        f"Pontos: {jogador['pontos']}"
                    )

                    tecla = input(
                        "Mover (WASD): "
                    ).lower()

                    venceu = mover(
                        tecla,
                        jogador,
                        lab
                    )

                    movimentos += 1

                if venceu:

                    animacao_vitoria(5)

                    print(
                        f"Parabéns {args.name}!"
                    )

                else:

                    print("Fim de jogo!")

            case "2":
                imprimir_instrucoes()

            case "3":

                lab = criar_labirinto()

                caminho = resolver_labirinto(
                    lab,
                    1,
                    1
                )

                print("Solução encontrada:")
                print(caminho)

                time.sleep(3)

            case "4":
                break

            case _:
                print("Opção inválida")


if __name__ == "__main__":
    main()
