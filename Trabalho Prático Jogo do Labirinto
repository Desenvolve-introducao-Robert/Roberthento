"""
Funções utilitárias do jogo.
"""

import time
from rich.console import Console
from rich.panel import Panel

console = Console()


def imprimir_menu():
    """
    Mostra menu inicial.
    """

    console.print(
        Panel.fit(
            "[bold green]Aventura no Labirinto[/bold green]\n"
            "1 - Jogar\n"
            "2 - Instruções\n"
            "3 - Resolver automaticamente\n"
            "4 - Sair"
        )
    )


def imprimir_instrucoes():
    """
    Lê e imprime instruções do arquivo.
    """

    with open("docs/instrucoes.txt", "r", encoding="utf-8") as arq:
        texto = arq.read()

    console.print(Panel(texto))


def animacao_vitoria(n):
    """
    Animação recursiva de vitória.

    Args:
        n (int): quantidade de repetições
    """

    if n == 0:
        return

    console.print("[bold yellow]VOCÊ VENCEU![/bold yellow]")
    time.sleep(0.3)

    animacao_vitoria(n - 1)
