"""
Módulo responsável pela criação e impressão do labirinto.
"""

import random
from rich.console import Console

console = Console()


def criar_labirinto(largura=10, altura=10):
    """
    Cria um labirinto aleatório.

    Args:
        largura (int): largura do mapa
        altura (int): altura do mapa

    Returns:
        list: matriz representando o labirinto
    """

    lab = []

    for y in range(altura):
        linha = []

        for x in range(largura):

            if x == 0 or y == 0 or x == largura - 1 or y == altura - 1:
                linha.append("#")
            else:
                if random.randint(0, 4) == 0:
                    linha.append("#")
                else:
                    linha.append(" ")

        lab.append(linha)

    lab[1][1] = "J"
    lab[altura - 2][largura - 2] = "S"

    for _ in range(3):
        x = random.randint(1, largura - 2)
        y = random.randint(1, altura - 2)

        if lab[y][x] == " ":
            lab[y][x] = "*"

    return lab


def imprimir_labirinto(lab):
    """
    Imprime o labirinto formatado.

    Args:
        lab (list): matriz do labirinto
    """

    console.clear()

    for linha in lab:

        texto = ""

        for item in linha:

            if item == "#":
                texto += "[red]█[/red]"
            elif item == "J":
                texto += "[green]😀[/green]"
            elif item == "S":
                texto += "[yellow]🏁[/yellow]"
            elif item == "*":
                texto += "[cyan]★[/cyan]"
            else:
                texto += " "

        console.print(texto)
