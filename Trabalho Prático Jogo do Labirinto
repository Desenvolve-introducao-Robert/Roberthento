"""
Módulo responsável pelas ações do jogador.
"""

from pynput import keyboard


def iniciar_jogador():
    """
    Inicializa os dados do jogador.

    Returns:
        dict: informações do jogador
    """

    return {
        "x": 1,
        "y": 1,
        "pontos": 0
    }


def pontuar(jogador, valor):
    """
    Atualiza pontuação do jogador.

    Args:
        jogador (dict): dados do jogador
        valor (int): pontos recebidos
    """

    jogador["pontos"] += valor


def mover(tecla, jogador, lab):
    """
    Move o jogador pelo mapa.

    Args:
        tecla: tecla pressionada
        jogador (dict): dados do jogador
        lab (list): mapa do jogo

    Returns:
        bool: True se venceu
    """

    x = jogador["x"]
    y = jogador["y"]

    novo_x = x
    novo_y = y

    if tecla == "w":
        novo_y -= 1

    elif tecla == "s":
        novo_y += 1

    elif tecla == "a":
        novo_x -= 1

    elif tecla == "d":
        novo_x += 1

    destino = lab[novo_y][novo_x]

    if destino != "#":

        if destino == "*":
            pontuar(jogador, 10)

        if destino == "S":
            return True

        lab[y][x] = " "
        lab[novo_y][novo_x] = "J"

        jogador["x"] = novo_x
        jogador["y"] = novo_y

    return False


def resolver_labirinto(lab, x, y, visitados=None):
    """
    Função recursiva que encontra saída do labirinto.

    Args:
        lab (list): mapa
        x (int): posição x
        y (int): posição y
        visitados (set): posições visitadas

    Returns:
        list: caminho da solução
    """

    if visitados is None:
        visitados = set()

    if (x, y) in visitados:
        return None

    visitados.add((x, y))

    if lab[y][x] == "S":
        return []

    movimentos = [
        ("w", x, y - 1),
        ("s", x, y + 1),
        ("a", x - 1, y),
        ("d", x + 1, y)
    ]

    for direcao, nx, ny in movimentos:

        if lab[ny][nx] != "#":

            resultado = resolver_labirinto(
                lab,
                nx,
                ny,
                visitados
            )

            if resultado is not None:
                return [direcao] + resultado

    return None
