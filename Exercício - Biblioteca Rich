Python"""
Módulo estilo: Funcionalidades de estilo e cores da biblioteca Rich.
"""

from rich.console import Console
from rich.text import Text
import os


def texto_colorido(texto: str, is_arquivo: bool = False) -> None:
    """
    Exibe o texto com múltiplas cores e estilos.
    """
    console = Console()
    if is_arquivo and os.path.exists(texto):
        with open(texto, 'r', encoding='utf-8') as f:
            conteudo = f.read()
    else:
        conteudo = texto

    texto_formatado = Text()
    texto_formatado.append("✨ ", style="bold magenta")
    texto_formatado.append(conteudo, style="bold cyan")
    console.print(texto_formatado)


def texto_com_efeitos(texto: str, is_arquivo: bool = False) -> None:
    """
    Exibe texto com negrito, itálico, underline e cores.
    """
    console = Console()
    if is_arquivo and os.path.exists(texto):
        with open(texto, 'r', encoding='utf-8') as f:
            conteudo = f.read()
    else:
        conteudo = texto

    console.print(f"[bold red]TÍTULO:[/bold red] [italic green]{conteudo[:100]}[/italic green]")
    console.print(f"[underline blue]{conteudo}[/underline blue]")

