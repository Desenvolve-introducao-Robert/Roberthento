Python"""
Módulo layout: Funcionalidades de layout da biblioteca Rich.
"""

from rich.console import Console
from rich.panel import Panel
from rich.layout import Layout
from rich.align import Align
import os


def centralizado(texto: str, is_arquivo: bool = False) -> None:
    """
    Exibe o texto centralizado na tela usando Align.

    Args:
        texto (str): Texto ou caminho do arquivo.
        is_arquivo (bool): Se True, lê o conteúdo do arquivo.
    """
    console = Console()
    if is_arquivo and os.path.exists(texto):
        with open(texto, 'r', encoding='utf-8') as f:
            conteudo = f.read()
    else:
        conteudo = texto

    console.print(Align.center(conteudo, vertical="middle"), width=80)


def layout_dividido(texto: str, is_arquivo: bool = False) -> None:
    """
    Exibe o texto em um layout dividido (2 colunas) usando Rich Layout.
    """
    console = Console()
    if is_arquivo and os.path.exists(texto):
        with open(texto, 'r', encoding='utf-8') as f:
            conteudo = f.read()
    else:
        conteudo = texto

    layout = Layout()
    layout.split_row(
        Layout(name="left"),
        Layout(name="right")
    )
    layout["left"].update(Panel(conteudo, title="Esquerda"))
    layout["right"].update(Panel("Conteúdo adicional ou menu", title="Direita"))

    console.print(layout)
