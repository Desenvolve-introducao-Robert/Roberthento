Python"""
Interface de linha de comando para o pacote personalizador.
"""

import argparse
import sys
import os
from personalizador import layout, painel, progresso, estilo

# Mapeamento de módulos e funções
MODULOS = {
    "1": layout,
    "2": painel,
    "3": progresso,
    "4": estilo,
    "layout": layout,
    "painel": painel,
    "progresso": progresso,
    "estilo": estilo,
}

FUNCOES = {
    "layout": {
        "1": layout.centralizado,
        "2": layout.layout_dividido,
    },
    "painel": {
        "1": painel.painel_simples,
        "2": painel.painel_estilizado,
    },
    "progresso": {
        "1": progresso.progresso_simples,
        "2": progresso.spinner_carregamento,
    },
    "estilo": {
        "1": estilo.texto_colorido,
        "2": estilo.texto_com_efeitos,
    }
}


def main():
    parser = argparse.ArgumentParser(
        description="Personalizador de Texto com Rich",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )

    parser.add_argument("texto", help="Texto ou caminho do arquivo")
    parser.add_argument("-a", "--arquivo", action="store_true",
                        help="Indica que o argumento 'texto' é um caminho de arquivo")
    parser.add_argument("-m", "--modulo", required=True,
                        help="""Módulo a ser usado:
1 ou layout
2 ou painel
3 ou progresso
4 ou estilo""")
    parser.add_argument("-f", "--funcao", required=True,
                        help="""Função do módulo:
1 ou 2 (dependendo do módulo)""")

    args = parser.parse_args()

    modulo = MODULOS.get(args.modulo.lower() if args.modulo.lower() in ["layout", "painel", "progresso", "estilo"] else args.modulo)
    if not modulo:
        print("❌ Módulo inválido!")
        sys.exit(1)

    # Obter função
    funcoes_modulo = FUNCOES.get(args.modulo.lower() if args.modulo.lower() in FUNCOES else args.modulo, {})
    funcao = funcoes_modulo.get(args.funcao)
    if not funcao:
        print("❌ Função inválida!")
        sys.exit(1)

    funcao(args.texto, args.arquivo)


if __name__ == "__main__":
    main()

