Python"""
Módulo progresso: Funcionalidades de barra de progresso da biblioteca Rich.
"""

from rich.console import Console
from rich.progress import Progress, SpinnerColumn, TextColumn, BarColumn, TaskProgressColumn
import time
import os


def progresso_simples(texto: str, is_arquivo: bool = False) -> None:
    """
    Simula processamento do texto com barra de progresso.
    """
    console = Console()
    if is_arquivo and os.path.exists(texto):
        with open(texto, 'r', encoding='utf-8') as f:
            conteudo = f.read()
    else:
        conteudo = texto

    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        BarColumn(),
        TaskProgressColumn()
    ) as progress:
        task = progress.add_task("[cyan]Processando texto...", total=100)

        for i in range(100):
            progress.update(task, advance=1)
            time.sleep(0.02)

    console.print(f"[bold green]✓ Pronto![/bold green]\n{conteudo[:500]}{'...' if len(conteudo) > 500 else ''}")


def spinner_carregamento(texto: str, is_arquivo: bool = False) -> None:
    """
    Exibe spinner enquanto "carrega" o texto.
    """
    console = Console()
    if is_arquivo and os.path.exists(texto):
        with open(texto, 'r', encoding='utf-8') as f:
            conteudo = f.read()
    else:
        conteudo = texto

    with console.status("[bold yellow]Carregando conteúdo...[/bold yellow]", spinner="dots"):
        time.sleep(1.5)

    console.print(Panel(conteudo, title="Conteúdo Carregado", border_style="yellow"))
